  },
  "navigation": {
    "groups": [
      {
        "group": "Get Started",
        "pages": [
          "introduction",
          "getting-started/create-account",
          "getting-started/get-the-app"
        ]
      },
      {
        "group": "Recipes",
        "pages": [
          "recipes/import-from-url",
          "recipes/create-from-image",
          "recipes/create-manually",
          "recipes/bulk-import"
