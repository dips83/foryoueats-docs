{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Foryoueats",
  "theme": "aspen",
  "colors": {
    "primary": "#4a8077",
    "light": "#4a8077",
    "dark": "#4a8077"
  },
  "favicon": "https://media.brand.dev/981f7644-55fc-46fb-ab4f-22d11fbfaa27.webp",
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Go To Foryoueats",
      "href": "https://foryoueats.com/register"
